# Godot 4+ specific ignores
.godot/

# Android build
/android/

# iOS/macOS
*.dsym
*.dSYM.zip
*.ipa
*.apks
*.aab

# Windows
*.exe
*.pdb
*.apk

# Web/HTML5
*.js
*.html.zip

# Godot script UID files (auto-generated)
*.gd.uid

# Import files (auto-generated by Godot)
# Note: .import files are usually kept in version control for consistency
# Uncomment the following line if you want to ignore them:
# *.import

# Editor specific files
*.swp
*.swo
*~

# OS generated files
.DS_Store
.DS_Store?
._*
.Spotlight-V100
.Trashes
ehthumbs.db
Thumbs.db

# IDE/Editor
.idea/
.vscode/
*.sublime-project
*.sublime-workspace

# Logs
*.log
logs/

# Temporary files
*.tmp
*.temp
*.bak

# Build outputs
builds/
export/
exports/
dist/

# Documentation generated files (optional)
# docs/*.html